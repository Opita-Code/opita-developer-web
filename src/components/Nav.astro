---
// Nav.astro
---

<header class="fixed top-0 left-0 right-0 z-50 glass transition-all duration-300" id="main-nav">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group relative">
      <span class="font-mono text-2xl font-black text-white tracking-tighter">
        &gt;_ <span class="text-accent-primary">NICOLAS</span>
      </span>
      <div class="absolute -bottom-1 left-0 w-0 h-0.5 bg-accent-primary transition-all group-hover:w-full shadow-[0_0_10px_rgba(139,92,246,0.8)]"></div>
    </a>
    
    <nav class="hidden md:flex items-center gap-8 text-sm font-medium">
      <a href="#servicios" class="text-text-secondary hover:text-white transition-colors">Servicios</a>
      <a href="#proyectos" class="text-text-secondary hover:text-white transition-colors">Proyectos</a>
      <a href="#fundador" class="text-text-secondary hover:text-white transition-colors">Fundador</a>
      <a href="#contacto" class="px-5 py-2 rounded-md bg-zinc-800/80 hover:bg-zinc-700 border border-zinc-700 font-mono text-xs text-white transition-all hover:border-violet-500/50 hover:shadow-[0_0_15px_rgba(139,92,246,0.3)]">
        &lt;Contact /&gt;
      </a>
    </nav>
  </div>
</header>
